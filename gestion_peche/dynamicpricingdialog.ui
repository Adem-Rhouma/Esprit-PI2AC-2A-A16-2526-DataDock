    font-size: 12px;
}

QPushButton#btnClose {
    background: rgba(94, 96, 206, 15);
    border: 1px solid rgba(94, 96, 206, 80);
    border-radius: 16px;
    padding: 8px 18px;
    font-weight: 700;
}

QPushButton#btnExport {
    background: rgba(116, 0, 184, 12);
    border: 1px solid rgba(116, 0, 184, 80);
    border-radius: 16px;
    padding: 8px 18px;
    font-weight: 700;
}

QPushButton#btnExport:disabled {
    color: rgba(17, 24, 39, 120);
    background: rgba(94, 96, 206, 8);
    border: 1px solid rgba(94, 96, 206, 30);
}

QTableWidget#tableDynamicPricing {
    border: 1px solid rgba(94, 96, 206, 40);
    border-radius: 12px;
    gridline-color: rgba(94, 96, 206, 40);
}
