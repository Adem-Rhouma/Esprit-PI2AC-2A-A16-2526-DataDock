    font-weight: 700;
}

QLabel#lblIconSardine, QLabel#lblIconCalamar, QLabel#lblIconDorade {
    color: #FFFFFF;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #7400B8, stop:1 #5E60CE);
