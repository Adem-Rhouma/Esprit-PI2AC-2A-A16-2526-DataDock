   <string notr="true">
QMainWindow {
    background: transparent;
}

/* Container layers are transparent so paintEvent's bg.png shows through. */
QWidget#centralwidget,
QWidget#zoneContenu,
QStackedWidget#stackedPages {
    background: transparent;
}

QStatusBar {
    background-color: #f0f2f5;
}

QWidget#topBar {
    background-color: rgba(50, 90, 180, 235);
    border-bottom: 1px solid rgba(255, 255, 255, 60);
}

QWidget#sidebar {
    background-color: rgba(70, 140, 210, 220);
    border-right: 1px solid rgba(0, 0, 0, 60);
}

QWidget#topBar QLabel,
QWidget#sidebar QLabel {
    color: white;
}

QLabel#lblMainTitle {
    font-size: 32px;
    font-weight: 700;
    color: white;
}

QLabel#lblMainSubtitle {
    font-size: 16px;
    color: rgba(255, 255, 255, 220);
}

QPushButton#btnSidebarEmployes,
QPushButton#btnSidebarNavires,
QPushButton#btnSidebarChambres,
QPushButton#btnSidebarLogistique,
QPushButton#btnSidebarEquipements,
QPushButton#btnSidebarPeche,
QPushButton#btnSidebarLogout {
    background-color: rgba(255, 255, 255, 45);
    border: none;
    border-radius: 14px;
    color: white;
    font-size: 15px;
    padding: 10px 16px;
    text-align: left;
}

QPushButton#btnSidebarLogout {
    background-color: rgba(255, 255, 255, 70);
    color: #1f2a44;
    font-weight: 600;
}

QToolButton#btnParametres {
    border: none;
    color: white;
    font-size: 18px;
}

QPushButton#btnSidebarEmployes:checked,
QPushButton#btnSidebarNavires:checked,
QPushButton#btnSidebarChambres:checked,
QPushButton#btnSidebarLogistique:checked,
QPushButton#btnSidebarEquipements:checked,
QPushButton#btnSidebarPeche:checked {
    background-color: rgba(255, 255, 255, 95);
}
